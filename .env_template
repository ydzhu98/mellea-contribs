# Phase 4: Configuration Templates for mellea-contribs KG-RAG Pipeline
# Copy this file to .env and customize for your environment
# All variables are optional; defaults are provided by scripts

# ============================================================================
# Neo4j Backend Configuration
# ============================================================================
# Used by: run_kg_preprocess.py, run_kg_embed.py, run_kg_update.py, run_qa.py
# Default values work with local Neo4j installation on default port

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============================================================================
# LLM Model Configuration
# ============================================================================
# Used by: All scripts that need LLM calls (preprocess, embed, update, qa)
# Default: gpt-4o-mini (via LiteLLM)
# Supported: Any LiteLLM-routable model (OpenAI, Anthropic, HuggingFace, Ollama, etc.)

LLM_MODEL=gpt-4o-mini

# Optional: For non-OpenAI models, specify API base URL
# API_BASE=https://api.anthropic.com/v1
# API_KEY=your-key-here

# ============================================================================
# Embedding Model Configuration
# ============================================================================
# Used by: run_kg_embed.py
# Default: text-embedding-3-small (via LiteLLM)
# Supported: Any LiteLLM-routable embedding model

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============================================================================
# Data Processing Configuration
# ============================================================================
# Used by: Dataset creation and processing scripts

# Batch size for JSONL processing (default: 10)
BATCH_SIZE=10

# Number of examples in tiny dataset (default: 5)
TINY_DATASET_SIZE=5

# Number of examples in demo dataset (default: 20)
DEMO_DATASET_SIZE=20

# ============================================================================
# Logging Configuration
# ============================================================================
# Used by: All scripts via setup_logging()
# Levels: DEBUG, INFO, WARNING, ERROR

LOG_LEVEL=INFO

# Optional: Write logs to file (if not set, logs go to stderr only)
# LOG_FILE=/tmp/kgrag.log

# ============================================================================
# Pipeline Paths (Optional)
# ============================================================================
# These can be overridden via command-line arguments

# Default input/output directories
DATA_DIR=data/
OUTPUT_DIR=output/

# ============================================================================
# Features & Options
# ============================================================================
# Enable/disable optional features

# Use fuzzy matching instead of exact match in evaluation (default: false)
USE_FUZZY_MATCHING=false

# Fuzzy matching threshold (0.0-1.0, default: 0.8)
FUZZY_THRESHOLD=0.8

# Use progress bars (requires tqdm, default: true if available)
USE_PROGRESS_BARS=true

# ============================================================================
# Development/Testing
# ============================================================================
# Development overrides

# Use mock backend instead of Neo4j (for testing without database)
USE_MOCK_BACKEND=false

# Skip confirmation prompts (useful for automation)
SKIP_CONFIRMATION=false
